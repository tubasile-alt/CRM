modules = ["python-3.11", "postgresql-16"]
[agent]
expertMode = true
integrations = ["flask_authentication:1.0.0", "google-sheet:1.0.0", "google-calendar:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["freetype", "gdk-pixbuf", "glibcLocales", "gobject-introspection", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "pango", "tcl", "tk", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "flask-app"

[[workflows.workflow]]
name = "flask-app"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python /home/runner/workspace/app.py"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[[ports]]
localPort = 5002
externalPort = 3002

[[ports]]
localPort = 5003
externalPort = 3003

[[ports]]
localPort = 5004
externalPort = 4200

[[ports]]
localPort = 5005
externalPort = 5000

[[ports]]
localPort = 5006
externalPort = 5173

[[ports]]
localPort = 5904
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "--bind=0.0.0.0:5000", "--workers=2", "--threads=2", "--worker-class=gthread", "--timeout=120", "--access-logfile", "-", "--error-logfile", "-", "app:app"]

[userenv]

[userenv.shared]
VAPID_PUBLIC_KEY = "BB0Rb4wxmh8a_Hl5LvdiGJKXFJQDLqUqS9nwGYxCtJkz14jnJ05YcPlggYfSYc55NxG_cLaC8RMMjgkSrn9jQ1A"
VAPID_PRIVATE_KEY = "kY4rSTAm2HbZaIR-OFtRV5_H0EZUWoS79wTmBF60Ox8"
VAPID_CLAIMS_EMAIL = "mailto: tubasile@gmail.com"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
